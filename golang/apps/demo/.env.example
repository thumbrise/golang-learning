DOCKER_PORT_APP=10000
DOCKER_PORT_REDIS=10001
DOCKER_PORT_DB=10002
DOCKER_PORT_MAILPIT_WEB=10003
DOCKER_PORT_MAILPIT_SMTP=10004
DOCKER_PORT_POSTGRES_EXPORTER=10005
DOCKER_PORT_PYROSCOPE=10006
DOCKER_PORT_REDIS_INSIGHT=10007

APP_NAME=demo
APP_VERSION=1.0.0
APP_ENVIRONMENT=local
APP_DEBUG=false

DB_DATABASE=app
DB_HOST=db
DB_PORT=5432
DB_USERNAME=root
DB_PASSWORD=password

GOOSE_DRIVER=postgres
GOOSE_DBSTRING="postgres://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_DATABASE}"
GOOSE_MIGRATION_DIR=./db/migrations

AUTH_OTP_LENGTH=6
AUTH_OTP_TTL_MINUTES=3
#AUTH_OTP_FORCED_VALUE=123456

AUTH_JWT_SECRET=123456
AUTH_JWT_ISSUER=$APP_NAME
AUTH_JWT_ACCESS_TTL_MINUTES=5
# Week
AUTH_JWT_REFRESH_TTL_MINUTES=10080

HTTP_PORT=8080

MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=demo@demo.ru

OBSERVABILITY_PYROSCOPE_URL=http://pyroscope:4040
# Example for uptrace
OBSERVABILITY_OTLP_URL=host.docker.internal:4317
OBSERVABILITY_OTLP_TOKEN_KEY="uptrace-dsn"
OBSERVABILITY_OTLP_TOKEN_VALUE="http://someprojecttoken@uptrace:14318?grpc=4317"
OBSERVABILITY_PROMETHEUS_REMOTE_WRITE_URL="http://host.docker.internal:14318/api/v1/prometheus/write"

REDIS_URL=redis:6379
REDIS_DB=0
REDIS_PASSWORD=
